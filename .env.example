# ─────────────────────────────────────────────────────────────
# Anedya IoT Dashboard — Environment Variables
# Copy this file to .env and fill in your actual values.
# ─────────────────────────────────────────────────────────────

# ── App Configuration ─────────────────────────────────────────
# Custom name displayed on the login page and sidebar
VITE_APP_NAME="Anedya Dashoard Canvas"

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_PROJECT_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Anedya ────────────────────────────────────────────────────
# Found in: Anedya Dashboard → Project → API Keys
VITE_ANEDYA_API_KEY=your_anedya_api_key_here
